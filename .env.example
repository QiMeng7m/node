DATABASE_URL="file:./dev.db"

# JWT（必填，至少 16 字符；生产环境务必更换）
JWT_SECRET="dev-jwt-secret-change-in-production-min-16"
JWT_EXPIRES_IN="7d"

# 自助注册（默认开启；设为 false 则仅管理员可创建账号）
ALLOW_REGISTRATION="true"

# 新用户默认总配额（终身次数，非每日刷新）
DEFAULT_USER_QUOTA="50"

# 同一 IP 终身限制（0 表示不限制）
IP_CHAT_LIMIT="200"
IP_REGISTER_LIMIT="3"

# Cloudflare Turnstile 人机验证（留空则开发环境跳过）
# 测试密钥（始终通过）：site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# DeepSeek 官方 API
DEEPSEEK_API_KEY=""
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# LLM_PROVIDER_NAME="DeepSeek"
#
# 兼容旧变量（可选）：
# LLM_API_KEY=""
# LLM_BASE_URL="https://api.deepseek.com"
#
# 同步模型到线上（npm run sync:models）
# API_BASE_URL="https://你的线上域名"
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="你的密码"
# PROVIDER_ID=""                       # 可选，不填则按 PROVIDER_NAME 或唯一 Provider 匹配
# PROVIDER_NAME="DeepSeek"
# DRY_RUN="1"                          # 可选，只预览不写入

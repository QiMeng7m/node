generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  summary   String
  content   String   @default("")
  createdAt DateTime @default(now())
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  role         String        @default("user") // admin | user
  quotaLimit   Int           @default(100)
  quotaUsed    Int           @default(0)
  registeredIp String?
  proAccess    Boolean       @default(false) // 可使用 deepseek-v4-pro
  enabled      Boolean       @default(true)
  tokenVersion Int           @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]
}

model Provider {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  baseUrl   String
  apiKey    String
  protocol  String    @default("openai-compat") // openai-compat | anthropic
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  models    AiModel[]
}

model AiModel {
  id              String   @id
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  upstreamModelId String
  label           String
  description     String?
  tags            String   @default("[]")
  supportsVision  Boolean  @default(false)
  supportsStream  Boolean  @default(true)
  costTier        String   @default("low")
  recommended         Boolean  @default(false)
  requiresPermission  Boolean  @default(false)
  enabled             Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([providerId])
}

model Feature {
  id             String  @id
  name           String
  description    String
  icon           String?
  category       String
  modelPolicy    String
  defaultModelId String?
  systemPrompt   String  @default("")
  uiSchema       String  @default("{}")
  enabled        Boolean @default(true)
  sortOrder      Int     @default(0)
}

model ChatSession {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  defaultModelId String?
  featureId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String
  modelId     String?
  attachments String?
  createdAt   DateTime    @default(now())

  @@index([sessionId])
}

model UsageDaily {
  id     String @id @default(cuid())
  userId String
  date   String
  count  Int    @default(0)

  @@unique([userId, date])
}

/** 站点主人资料（单行 singleton，id 固定为 default） */
model SiteOwnerProfile {
  id        String   @id @default("default")
  data      String
  updatedAt DateTime @updatedAt
}

/** 按 IP 累计用量（防多号刷配额） */
model IpQuota {
  ip            String   @id
  chatCount     Int      @default(0)
  registerCount Int      @default(0)
  updatedAt     DateTime @updatedAt
}

DATABASE_URL="file:./dev.db"

# JWT（必填，至少 16 字符；生产环境务必更换）
JWT_SECRET="dev-jwt-secret-change-in-production-min-16"
JWT_EXPIRES_IN="7d"

# 自助注册（默认关闭，账号由管理员在数据库/后台创建）
ALLOW_REGISTRATION="false"

# JZ Internal / claude-jz.ps1 同源配置（Anthropic 协议）
# ANTHROPIC_API_KEY=""
# ANTHROPIC_BASE_URL="http://one-api.server22.jz"
# ANTHROPIC_MODEL="glm-5.1"          # 默认推荐模型，与 ps1 中 $env:ANTHROPIC_MODEL 相同
# LLM_PROVIDER_NAME="JZ Internal"
#
# 前端模型下拉切换 ≈ ps1 中修改 ANTHROPIC_MODEL；upstreamModelId 即模型名
#
# 兼容旧变量（可选）：
# LLM_API_KEY=""
# LLM_BASE_URL="https://api.deepseek.com/v1"
# LLM_MODEL="deepseek-chat"
# LLM_PROTOCOL="openai-compat"       # anthropic | openai-compat

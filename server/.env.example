DATABASE_URL="file:./dev.db"

# JWT（必填，至少 16 字符；生产环境务必更换）
JWT_SECRET="dev-jwt-secret-change-in-production-min-16"
JWT_EXPIRES_IN="7d"

# 自助注册（默认关闭，账号由管理员在数据库/后台创建）
ALLOW_REGISTRATION="false"

# LLM Provider（配置后 db:seed 会写入模型；未配置则模型列表为空，无法对话）
# LLM_BASE_URL="https://api.deepseek.com/v1"
# LLM_API_KEY=""
# LLM_MODEL="deepseek-chat"
# LLM_CODER_MODEL="deepseek-coder"
# LLM_PROVIDER_NAME="DeepSeek"
